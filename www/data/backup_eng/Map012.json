{"id":5,"name":"EV005","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":["There is a diary that I started to write after coming to"]},{"code":401,"indent":0,"parameters":["this world."]},{"code":401,"indent":0,"parameters":["It's a little long, but why not read it again?"]},{"code":401,"indent":0,"parameters":["(You can skip the lines at high speed with the S key.)"]},{"code":102,"indent":0,"parameters":[["Read","Don't read"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"Read"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["~ Day 1 ~"]},{"code":401,"indent":1,"parameters":["I found myself in a bed in an unknown town."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["Where am I?"]},{"code":401,"indent":1,"parameters":["I don't recognize any landmarks, no matter how far I look."]},{"code":401,"indent":1,"parameters":["For now, let's ask someone where I am."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["Strange."]},{"code":401,"indent":1,"parameters":["He doesn't answer my questions and he's been repeating"]},{"code":401,"indent":1,"parameters":["the same lines over and over."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["No use. Others are also repeating their same lines."]},{"code":401,"indent":1,"parameters":["Where is this place? What the hell are these guys"]},{"code":401,"indent":1,"parameters":["prattling on about?"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["I was hungry so I went to the store, it seems that the"]},{"code":401,"indent":1,"parameters":["yen cannot be used here."]},{"code":401,"indent":1,"parameters":["In other words, the clerk only repeats the same lines."]},{"code":401,"indent":1,"parameters":["For the time being, let's endure without rice today..."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["~Day 2~"]},{"code":401,"indent":1,"parameters":["Let's put off finding out where I am right now."]},{"code":401,"indent":1,"parameters":["Anyway, securing food is the highest priority."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["I haven't eaten anything at all and now I have no choice"]},{"code":401,"indent":1,"parameters":["but to walk around the town."]},{"code":401,"indent":1,"parameters":["Can I eat something if I go to the castle over there..."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["Soldiers are eating."]},{"code":401,"indent":1,"parameters":["When I talked to the old lady in the kitchen, she was"]},{"code":401,"indent":1,"parameters":["preparing something."]},{"code":401,"indent":1,"parameters":["I ordered fried rice."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["My first meal in a day was so delicious."]},{"code":401,"indent":1,"parameters":["The warmth relieved my heart."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["I asked them what to do, but they still repeated only"]},{"code":401,"indent":1,"parameters":["the same lines."]},{"code":401,"indent":1,"parameters":["I've been able to secure food for the time being."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["~ Day 3 ~"]},{"code":401,"indent":1,"parameters":["I hurt my leg while taking a walk in the forest outside the city."]},{"code":401,"indent":1,"parameters":["That's all for today. I'm tired, so i'm gonna eat and sleep early."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["~ Day 4 ~"]},{"code":401,"indent":1,"parameters":["The injury from yesterday is completely gone."]},{"code":401,"indent":1,"parameters":["I didn't dream. I'm sure I injured my leg."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["\"It's like in a game where if you sleep in an inn,"]},{"code":401,"indent":1,"parameters":["you completely recover afterwards.\""]},{"code":401,"indent":1,"parameters":["While I was puzzled from this mysterious phenomenon,"]},{"code":401,"indent":1,"parameters":["I was suddenly enjoying an extraordinary life."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["~ Day 5 ~"]},{"code":401,"indent":1,"parameters":["Strange."]},{"code":401,"indent":1,"parameters":["I used a medicinal herb that was on the desk in"]},{"code":401,"indent":1,"parameters":["the storeroom of my house,"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["but when I checked the storeroom some time after"]},{"code":401,"indent":1,"parameters":["that, I found that it was there again."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["Did someone sneak in and put it there?"]},{"code":401,"indent":1,"parameters":["I double checked the door lock and went to the castle to eat."]},{"code":401,"indent":1,"parameters":["I had an omelet today."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["~Day 6~"]},{"code":401,"indent":1,"parameters":["Before going to bed, I confirmed that there was no medicinal"]},{"code":401,"indent":1,"parameters":["herb in the storeroom, when I went to check in the morning there were"]},{"code":401,"indent":1,"parameters":["multiple medicinal herbs."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["People who repeat the same lines."]},{"code":401,"indent":1,"parameters":["Wounds that heal after waking up from sleeping."]},{"code":401,"indent":1,"parameters":["It seems like I'm in a game."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～Day 7～"]},{"code":401,"indent":1,"parameters":["I had a cold, but when I went to bed as expected, I was completely"]},{"code":401,"indent":1,"parameters":["cured. The scratches when I grazed my knee yesterday are gone."]},{"code":401,"indent":1,"parameters":["Maybe... this world really is in a game...?"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～Day 8～"]},{"code":401,"indent":1,"parameters":["I'm still not sure what happened to me, but it seems certain"]},{"code":401,"indent":1,"parameters":["that I'm not in any danger so far."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["As soon as I knew it was safe, I was exhausted and dropped"]},{"code":401,"indent":1,"parameters":["a cup I had in my hand."]},{"code":401,"indent":1,"parameters":["Oh well. It will be fixed tomorrow anyway."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["Let's say this world is in a game."]},{"code":401,"indent":1,"parameters":["If so, what should I do from now on?"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["I've been moving for the past few days, so it's a good"]},{"code":401,"indent":1,"parameters":["idea to carefully think about what I'm gonna do today."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～Day 9～"]},{"code":401,"indent":1,"parameters":["If this world is in a game, there's something I want to"]},{"code":401,"indent":1,"parameters":["check for now."]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["If my expectations are correct, I might find one fun thing"]},{"code":401,"indent":1,"parameters":["to do while living in this world."]},{"code":401,"indent":1,"parameters":["I'm getting excited. Let's go to bed early today for tomorrow."]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"Don't read"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":3},
