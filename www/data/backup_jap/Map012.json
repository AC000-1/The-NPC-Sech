{"id":5,"name":"EV005","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["",0,2,2]},{"code":401,"indent":0,"parameters":["この世界に来てから書き始めた日記がある。"]},{"code":401,"indent":0,"parameters":["少し長いけど、改めて読んでみようか？"]},{"code":401,"indent":0,"parameters":["（Ｓキーでメッセージの高速スキップが出来ます。）"]},{"code":102,"indent":0,"parameters":[["読む","読まない"],1,0,2,0]},{"code":402,"indent":0,"parameters":[0,"読む"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～１日目～"]},{"code":401,"indent":1,"parameters":["気が付くと知らない町のベッドの中にいた。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["ここはどこだ？"]},{"code":401,"indent":1,"parameters":["どこまで行っても見たことのない景色が続いている。"]},{"code":401,"indent":1,"parameters":["とりあえず、ここがどこなのか誰かに尋ねてみよう。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["おかしい。"]},{"code":401,"indent":1,"parameters":["質問には答えてくれないし、"]},{"code":401,"indent":1,"parameters":["この人はさっきからずっと同じことをしゃべり続けている。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["ダメだ。他の人も同じことしか喋らない。"]},{"code":401,"indent":1,"parameters":["ここはどこだ？こいつらは一体なんなんだ？"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["お腹が空いたからお店に行ってみたが、ここでは円が使えないようだ。"]},{"code":401,"indent":1,"parameters":["というか店員さんも同じことしか喋らない。"]},{"code":401,"indent":1,"parameters":["ひとまず今日は飯抜きで我慢しよう……。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～２日目～"]},{"code":401,"indent":1,"parameters":["ここがどこなのかは後回しだ。"]},{"code":401,"indent":1,"parameters":["とにかく食料の確保が最優先だ。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["飯のあてなんて全くないが、今は町を歩き回ってみるしかない。"]},{"code":401,"indent":1,"parameters":["向こうに見える城に行けば何か食べられるだろうか……。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["兵士たちが食事をしている。"]},{"code":401,"indent":1,"parameters":["厨房のおばちゃんに話かけてみると、何か作ってくれるらしい。"]},{"code":401,"indent":1,"parameters":["俺はチャーハンを頼んだ。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["１日ぶりの飯はすこぶる美味い。"]},{"code":401,"indent":1,"parameters":["温かさで心がほっとする。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["お代はどうすれば良いのか聞いてみたが、"]},{"code":401,"indent":1,"parameters":["やはり同じことしか繰り返さない。"]},{"code":401,"indent":1,"parameters":["とりあえず食料の確保は出来たのかもしれない。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～３日目～"]},{"code":401,"indent":1,"parameters":["街外れの森を散策していたら足に怪我をしてしまった。"]},{"code":401,"indent":1,"parameters":["今日はここまでだ。疲れたし、飯を食って早めに寝よう。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～４日目～"]},{"code":401,"indent":1,"parameters":["昨日の傷が綺麗さっぱり無くなっている。"]},{"code":401,"indent":1,"parameters":["思い違いではない。確かに足を怪我したはずだ。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["「寝たら完全回復するなんて、まるでゲームの宿屋みたいだ」"]},{"code":401,"indent":1,"parameters":["不可解な現象に首を傾げながらも、"]},{"code":401,"indent":1,"parameters":["突然の非日常をちょっと楽しんでしまっている自分がいた。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～５日目～"]},{"code":401,"indent":1,"parameters":["おかしい。"]},{"code":401,"indent":1,"parameters":["家の倉庫にあったやくそうを机の上に置いておいたのだが、"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["さっき倉庫を確認したら、またやくそうが入っていた。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["誰かが忍び込んで入れたのか？"]},{"code":401,"indent":1,"parameters":["戸締りを再確認して、城へご飯を食べに行く。"]},{"code":401,"indent":1,"parameters":["今日はオムレツにしよう。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～６日目～"]},{"code":401,"indent":1,"parameters":["寝る前に、倉庫にやくそうが無いことを確認したのだが、"]},{"code":401,"indent":1,"parameters":["朝 確認しに行ったらまたやくそうが増えていた。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["同じセリフを繰り返す人々。"]},{"code":401,"indent":1,"parameters":["寝れば治る傷や復活する物。"]},{"code":401,"indent":1,"parameters":["これじゃあまるでゲームの中みたいだ。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～７日目～"]},{"code":401,"indent":1,"parameters":["風邪を引いたが、予想通り寝たら完璧に治ってしまった。"]},{"code":401,"indent":1,"parameters":["昨日 転んで擦りむいた傷も全く残っていない。"]},{"code":401,"indent":1,"parameters":["もしかして……本当にゲームの中の世界……？"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～８日目～"]},{"code":401,"indent":1,"parameters":["俺の身に何が起こったのかはまだ定かではないが、"]},{"code":401,"indent":1,"parameters":["今のところ身の危険が無いということだけは確かなようだ。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["安全だと分かった途端、気が抜けてしまい"]},{"code":401,"indent":1,"parameters":["手に持っていたコップを落として割ってしまった。"]},{"code":401,"indent":1,"parameters":["まあいい。どうせ明日には直っている。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["仮にこの世界がゲームの中だとしよう。"]},{"code":401,"indent":1,"parameters":["その場合、俺はこれから何をすれば良いのだろうか。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["ここ数日間は動きっぱなしだったから"]},{"code":401,"indent":1,"parameters":["今日は一日、これからについて"]},{"code":401,"indent":1,"parameters":["ゆっくりと考えてみるのも良いかもしれない。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["～９日目～"]},{"code":401,"indent":1,"parameters":["もしこの世界がゲームの中だとしたら、"]},{"code":401,"indent":1,"parameters":["とりあえず確認しておきたいことがある。"]},{"code":101,"indent":1,"parameters":["",0,2,2]},{"code":401,"indent":1,"parameters":["俺の予想が正しければ、"]},{"code":401,"indent":1,"parameters":["この世界で生きる楽しみが一つ見つかるかもしれない。"]},{"code":401,"indent":1,"parameters":["緊張してきた。明日に備えて今日は早めに寝てしまおう。"]},{"code":0,"indent":1,"parameters":[]},{"code":402,"indent":0,"parameters":[1,"読まない"]},{"code":0,"indent":1,"parameters":[]},{"code":404,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":1,"stepAnime":false,"through":false,"trigger":0,"walkAnime":true}],"x":10,"y":3},
